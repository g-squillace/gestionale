---
export const prerender = false;
import '../styles/global.css';
import ProdottoItem from '../components/ProdottoItem.astro';
import { supabase, type Prodotto, type Richiesta } from '../lib/supabase';

const [prodottiRes, richiesteRes] = await Promise.all([
  supabase.from('prodotti').select('*').order('created_at', { ascending: false }),
  supabase.from('richieste').select('*').order('created_at', { ascending: false }),
]);

const prodotti = (prodottiRes.data ?? []) as Prodotto[];
const richieste = (richiesteRes.data ?? []) as Richiesta[];

const sortInStockFirst = (a: Prodotto, b: Prodotto) =>
  (a.quantita <= 0 ? 1 : 0) - (b.quantita <= 0 ? 1 : 0);

const patch = prodotti.filter((p) => p.tipo !== 'nameset').sort(sortInStockFirst);
const nameset = prodotti.filter((p) => p.tipo === 'nameset').sort(sortInStockFirst);
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Magazzino</title>
  </head>
  <body class="bg-slate-100 min-h-screen text-slate-800">
    <header class="bg-slate-900 text-white">
      <div class="max-w-5xl mx-auto px-4 py-4 space-y-3">
        <div class="flex items-center justify-between">
          <h1 class="text-lg font-bold">Magazzino</h1>
          <button
            id="btn-logout"
            class="text-sm bg-slate-700 hover:bg-red-600 px-3 py-2 rounded-lg font-medium focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-amber-400"
          >
            Esci
          </button>
        </div>
        <input
          id="search"
          type="search"
          autocomplete="off"
          aria-label="Cerca prodotto per titolo"
          placeholder="Cerca per titolo…"
          class="w-full text-lg px-5 py-3.5 rounded-xl bg-white text-slate-800 placeholder-slate-400 focus:ring-4 focus:ring-amber-500/40 outline-none"
        />
      </div>
    </header>

    <main class="max-w-5xl mx-auto px-4 py-6 space-y-10">
      <div id="prodotti-area" class="grid gap-8 md:grid-cols-2">
        <section aria-labelledby="patch-title">
          <div class="flex items-center justify-between mb-4">
            <h2 id="patch-title" class="text-xl font-bold">Patch</h2>
            <button
              data-nuovo="patch"
              class="bg-amber-500 hover:bg-amber-600 text-slate-900 font-semibold px-3 py-2 rounded-lg flex items-center gap-1.5 text-sm focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
            >
              <span class="text-lg leading-none">+</span> Nuova
            </button>
          </div>

          <p class={`js-empty text-slate-500 text-center py-10 ${patch.length ? 'hidden' : ''}`}>
            Nessuna patch.
          </p>

          <ul data-list="patch" class="space-y-3">
            {patch.map((p) => <ProdottoItem prodotto={p} />)}
          </ul>
        </section>

        <section aria-labelledby="nameset-title">
          <div class="flex items-center justify-between mb-4">
            <h2 id="nameset-title" class="text-xl font-bold">Nameset</h2>
            <button
              data-nuovo="nameset"
              class="bg-amber-500 hover:bg-amber-600 text-slate-900 font-semibold px-3 py-2 rounded-lg flex items-center gap-1.5 text-sm focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
            >
              <span class="text-lg leading-none">+</span> Nuovo
            </button>
          </div>

          <p class={`js-empty text-slate-500 text-center py-10 ${nameset.length ? 'hidden' : ''}`}>
            Nessun nameset.
          </p>

          <ul data-list="nameset" class="space-y-3">
            {nameset.map((p) => <ProdottoItem prodotto={p} />)}
          </ul>
        </section>
      </div>

      <section aria-labelledby="richieste-title">
        <h2 id="richieste-title" class="text-xl font-bold mb-4">Richieste</h2>

        <form id="form-richiesta" class="flex flex-col sm:flex-row gap-2 mb-4">
          <input
            name="titolo"
            required
            placeholder="Titolo richiesta"
            class="flex-1 px-3 py-2.5 rounded-lg border border-slate-300 bg-white focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
          />
          <input
            name="link"
            type="url"
            placeholder="Link (facoltativo)"
            class="flex-1 px-3 py-2.5 rounded-lg border border-slate-300 bg-white focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
          />
          <button
            type="submit"
            class="bg-slate-900 hover:bg-slate-700 text-white font-semibold px-4 py-2.5 rounded-lg focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-amber-400"
          >
            Aggiungi
          </button>
        </form>

        <p
          id="richieste-empty"
          class={`text-slate-500 text-center py-6 ${richieste.length ? 'hidden' : ''}`}
        >
          Nessuna richiesta.
        </p>

        <ul id="richieste-list" class="space-y-2">
          {
            richieste.map((r) => (
              <li
                data-id={r.id}
                class="flex items-center justify-between gap-3 bg-white border border-slate-200 rounded-lg px-4 py-3"
              >
                <div class="min-w-0">
                  <p class="font-medium break-words">{r.titolo}</p>
                  {r.link && (
                    <a
                      href={r.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-sm text-amber-700 hover:underline break-all"
                    >
                      {r.link}
                    </a>
                  )}
                </div>
                <button class="js-richiesta-delete text-sm text-red-600 hover:text-red-700 font-medium shrink-0 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-red-600">
                  Fatto
                </button>
              </li>
            ))
          }
        </ul>
      </section>
    </main>

    <dialog
      id="dialog-prodotto"
      class="rounded-2xl p-0 w-[calc(100%-2rem)] max-w-md backdrop:bg-black/40 m-auto"
    >
      <form id="form-prodotto" class="p-6 space-y-4">
        <h2 id="dialog-title" class="text-lg font-bold">Nuovo prodotto</h2>
        <input type="hidden" name="id" />
        <div>
          <label class="block text-sm font-semibold mb-1" for="f-tipo">Tipo</label>
          <select
            id="f-tipo"
            name="tipo"
            class="w-full px-3 py-2.5 rounded-lg border border-slate-300 bg-white focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
          >
            <option value="patch">Patch</option>
            <option value="nameset">Nameset</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1" for="f-titolo">Titolo</label>
          <input
            id="f-titolo"
            name="titolo"
            required
            class="w-full px-3 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
          />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1" for="f-descrizione">Descrizione</label>
          <textarea
            id="f-descrizione"
            name="descrizione"
            rows="5"
            class="w-full px-3 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
          ></textarea>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="block text-sm font-semibold mb-1" for="f-prezzo">Prezzo acquisto (€)</label>
            <input
              id="f-prezzo"
              name="prezzo_acquisto"
              type="number"
              step="0.01"
              min="0"
              value="0"
              class="w-full px-3 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
            />
          </div>
          <div>
            <label class="block text-sm font-semibold mb-1" for="f-quantita">Quantità</label>
            <input
              id="f-quantita"
              name="quantita"
              type="number"
              step="1"
              min="0"
              value="1"
              class="w-full px-3 py-2.5 rounded-lg border border-slate-300 focus:border-amber-500 focus:ring-3 focus:ring-amber-500/20 outline-none"
            />
          </div>
        </div>
        <div class="flex gap-2 justify-end pt-2">
          <button
            type="button"
            id="dialog-cancel"
            class="px-4 py-2.5 rounded-lg font-medium hover:bg-slate-100 focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
          >
            Annulla
          </button>
          <button
            type="submit"
            class="bg-amber-500 hover:bg-amber-600 text-slate-900 font-semibold px-4 py-2.5 rounded-lg focus-visible:outline-3 focus-visible:outline-offset-2 focus-visible:outline-slate-900"
          >
            Salva
          </button>
        </div>
      </form>
    </dialog>

    <div
      id="toast"
      class="fixed bottom-4 left-1/2 -translate-x-1/2 bg-slate-900 text-white px-4 py-2.5 rounded-lg text-sm font-medium shadow-lg opacity-0 pointer-events-none transition-opacity"
      role="status"
      aria-live="polite"
    >
    </div>

    <script src="../scripts/magazzino.ts"></script>
  </body>
</html>
